{
    "override_default_auth": true,
    "login_credential": "email",
    "username": {
        "min_length": 3,
        "max_length": 20,
        "pattern": "^[a-zA-Z0-9._-]+$",
        "case_sensitive": false
    },
    "features": {
        "registration": true,
        "email_verification": true,
        "auto_login_after_registration": false,
        "two_factor": true,
        "email_otp": true,
        "totp": true,
        "remember_me": true,
        "password_reset": true
    },
    "two_factor": {
        "email_otp": {
            "enabled": true,
            "expiry_minutes": 10
        },
        "totp": {
            "enabled": true,
            "issuer": "Laravel",
            "window": 1,
            "backup_codes_count": 8,
            "backup_code_length": 8
        }
    },
    "security": {
        "max_login_attempts": 5,
        "block_duration_minutes": 30,
        "require_2fa_for_dev": true
    },
    "session": {
        "lifetime": 120,
        "expire_on_close": false
    },
    "routes": {
        "override_prefix": "",
        "backend_prefix": "/apps",
        "backend_name_prefix": "backend",
        "after_login": "home.dashboard",
        "after_logout": "home.landing",
        "middleware": [
            "web"
        ]
    }
}